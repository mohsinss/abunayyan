# Copy to .env.local and fill in. See docs/setup/01-environment.md.

# ---------- Core
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---------- Database (Neon - doc 02)
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require
DATABASE_URL_UNPOOLED=postgresql://user:pass@host-direct/db?sslmode=require

# ---------- Auth (Auth.js v5 - doc 03)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=REPLACE_ME_32_OR_MORE_BYTES_BASE64
# Google OAuth (console.cloud.google.com -> Credentials -> OAuth 2.0 Client ID)
# Authorized redirect URIs:
#   http://localhost:3000/api/auth/callback/google
#   https://<your-vercel-url>/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# AUTH_URL is auto-detected on Vercel; set only to override locally.
# AUTH_URL=http://localhost:3000

# ---------- AI providers (platform doc 05 — at least one is required)
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME
# OPENAI_API_KEY=sk-REPLACE_ME
# GOOGLE_GENERATIVE_AI_API_KEY=AIza-REPLACE_ME
# XAI_API_KEY=xai-REPLACE_ME

# ---------- Admin bootstrap
# Promote this email to "owner" on the first `pnpm db:seed`.
# SEED_OWNER_EMAIL=you@company.com

# ---------- Ops escape hatches (use only during incidents)
# DISABLE_RATELIMIT=1
# ENABLE_AI_TRACES=1

# ---------- Payments (Stripe - doc 06)
# STRIPE_SECRET_KEY=sk_test_REPLACE_ME
# STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# ---------- Email (Resend - doc 07)
# RESEND_API_KEY=re_REPLACE_ME
# EMAIL_FROM="Magic Create <hello@magic-create.com>"

# ---------- Observability (doc 08)
# NEXT_PUBLIC_SENTRY_DSN=https://REPLACE_ME@sentry.io/REPLACE_ME
# SENTRY_AUTH_TOKEN=sntrys_REPLACE_ME
# SENTRY_ORG=your-org
# SENTRY_PROJECT=your-project
# NEXT_PUBLIC_POSTHOG_KEY=phc_REPLACE_ME
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ---------- Upstash (doc 09)
# UPSTASH_REDIS_REST_URL=https://REPLACE_ME.upstash.io
# UPSTASH_REDIS_REST_TOKEN=REPLACE_ME
# QSTASH_TOKEN=REPLACE_ME
# QSTASH_CURRENT_SIGNING_KEY=REPLACE_ME
# QSTASH_NEXT_SIGNING_KEY=REPLACE_ME
